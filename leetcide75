def consucutivity_lenth(nums):
    num_set = set(nums)
    longest = 0

    for num in num_set:
        #check the sequence
        if num -1 not in num_set:
            current = num
            lenght = 1
            
            while current +1 in num_set:
                current +=1
                lenght +=1
        
            longest = max(longest, lenght)
    return longest

